<IfModule mod_rewrite.c>
    RewriteEngine On

    # Protect application sources when the project root is the DocumentRoot.
    RewriteRule ^(?:app|config|database|scripts|vendor|storage|\.git|\.env)(?:/|$) - [F,L,NC]
    RewriteRule ^(?:composer\.(?:json|lock)|README\.md)$ - [F,L,NC]

    # Stop rewriting once the request has already been routed to /public.
    RewriteRule ^public(?:/|$) - [L]

    # Route public requests to the web entry directory.
    RewriteRule ^$ public/ [L]
    RewriteRule ^(.+)$ public/$1 [L]
</IfModule>
