<IfModule mod_rewrite.c>
    RewriteEngine On

    # Portable rules: local /WAKE and VPS domain root.
    RewriteRule (^|/)\. - [F,L]
    RewriteRule .*\.(?:env|ini|log|sql|bak|config|lock|md|php~)$ - [F,L,NC]
    RewriteRule ^uploads/.*\.(php|phtml|phar|cgi|pl|py|sh|asp|aspx|jsp)$ - [F,L,NC]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>
