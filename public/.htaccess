Options -Indexes

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(env|ini|log|sql|bak|config|lock|md|php~)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # No fixed RewriteBase: this works both under /WAKE locally and at /
    # when the VPS domain points directly to this public directory.
    RewriteRule (^|/)\. - [F,L]
    RewriteRule ^uploads/.*\.(php|phtml|phar|cgi|pl|py|sh|asp|aspx|jsp)$ - [F,L,NC]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,END]
</IfModule>
